# ==========================================
#  言外 - 环境变量配置模板
#  复制此文件为 .env 并填入实际值
# ==========================================

# ---------- AI 配置 ----------
# 文本分析 AI（支持 OpenAI 兼容格式）
YANWAI_AI_API_KEY=sk-your-api-key-here
YANWAI_AI_BASE_URL=https://api.deepseek.com
YANWAI_AI_MODEL=deepseek-v4-flash

# 视觉 AI（默认豆包视觉模型）
YANWAI_AI_VISION_API_KEY=your-vision-api-key
YANWAI_AI_VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
YANWAI_AI_VISION_MODEL=doubao-seed-2-0-lite-260428
OCR_API_KEY=your-ocr-api-key

# ---------- 数据库配置 ----------
# 不填写则使用 application.yml 中的默认值
# DB_URL=jdbc:mysql://localhost:3306/yanwai?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
# DB_USERNAME=root
# DB_PASSWORD=your-password

# ---------- 游戏配置 ----------
# 不填写则使用 application.yml 中的默认值
# CARD_DROP_PROBABILITY=0.3
# FREE_DAILY_ANALYSIS=3
